# =============================================================================
# OST (On-Screen Translator) - environment configuration EXAMPLE
# Copy to .env.local and fill real values. Real env files are gitignored and
# hook-blocked from agent reads; this file is the ONLY env file agents may read.
#
# IMPORTANT: end-user AI provider keys are NOT configured here. Users enter
# their keys in the app Settings UI and they are stored in the OS keychain
# (Windows Credential Manager) via the keyring crate. See
# .claude/rules/security-privacy.md. The variables below are DEV/CI ONLY.
# =============================================================================

# --- Logging (consumed by the Rust core via env_logger/tracing) --------------
# dev: .env.local / prod: not used (release builds default to warn)
RUST_LOG=info

# --- Integration-test provider keys (consumed by cargo/vitest integration
# tests that are normally MOCKED; only needed when explicitly running the
# opt-in live-API smoke tests. dev: .env.local / CI: GitHub Actions secrets) --
OST_TEST_GEMINI_API_KEY=your-gemini-test-key-here
OST_TEST_OPENAI_API_KEY=your-openai-test-key-here
OST_TEST_ANTHROPIC_API_KEY=your-anthropic-test-key-here
OST_TEST_OPENROUTER_API_KEY=your-openrouter-test-key-here

# --- Release signing (CI ONLY - GitHub Actions secrets; never in any local
# file. Used by tauri-action to sign the auto-updater artifacts.) -------------
# TAURI_SIGNING_PRIVATE_KEY=ci-only-github-secret
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=ci-only-github-secret
