# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
src-tauri/target/

# Vite local files
*.local

# Environment - real env files never committed (.env.example is the only committed one)
.env
.env.local
.env.*.local

# Claude Code local state
.claude/state/
.claude/worktrees/
.claude/settings.local.json

# Whisper / OCR model binaries (downloaded at first run, never committed).
# Root-anchored so it does NOT match the Rust source module
# `src-tauri/src/models/` (the shared model-consent facility).
/models/
*.bin
*.gguf
*.onnx

# Local dev helper: machine-specific vcvars cargo wrapper (hardcoded VS + worktree
# paths); not portable, so kept out of version control (known-issues.md).
scripts/cargo-wt.bat

# e2e (TASK-022): the pinned msedgedriver + WebView2 WebDriver artifacts are
# downloaded per host to match the installed WebView2 runtime; never committed.
e2e/.driver/

# OS noise
Thumbs.db
.DS_Store

# Logs
*.log
