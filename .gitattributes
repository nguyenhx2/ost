# Normalize all text files to LF in the repo and on checkout (prettier expects LF;
# GitHub windows runners default to autocrlf=true which broke CI otherwise).
* text=auto eol=lf

# Windows-native scripts need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaries
*.png binary
*.ico binary
*.icns binary
*.gif binary
*.jpg binary
*.woff2 binary
