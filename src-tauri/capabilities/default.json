{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and the region overlay windows",
  "windows": [
    "main",
    "region-select",
    "region-preview",
    "settings",
    "caption-overlay",
    "history"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-start-dragging",
    "clipboard-manager:allow-write-text",
    "store:default"
  ]
}
